# Database
DATABASE_URL="file:./prisma/dev.db"

# WSJ Credentials
WSJ_EMAIL=your_email@example.com
WSJ_PASSWORD=your_password
WSJ_STORAGE_PATH=./data/.wsj-auth.json

# Playwright remote browser (for Docker Compose browser service)
PLAYWRIGHT_WS_ENDPOINT=

# TTS Configuration (edge | openai)
TTS_PROVIDER=edge

# Optional: OpenAI TTS
OPENAI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
