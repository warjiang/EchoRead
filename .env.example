# Database
DATABASE_URL="file:./prisma/dev.db"

# WSJ Credentials
WSJ_EMAIL=your_email@example.com
WSJ_PASSWORD=your_password
WSJ_STORAGE_PATH=./data/.wsj-auth.json

# Deterministic WSJ worker
WSJ_WORKER_URL=http://localhost:8000/jobs
ORIGINAL_AUDIO_WORKER_URL=http://localhost:8000/audio/jobs
ORIGINAL_AUDIO_MIN_COVERAGE=0.9
ORIGINAL_AUDIO_MAX_ATTEMPTS=3
ORIGINAL_AUDIO_TIMEOUT_SECONDS=300
ORIGINAL_AUDIO_WHISPER_MODEL=base.en
ORIGINAL_AUDIO_WHISPER_DEVICE=cpu
ORIGINAL_AUDIO_WHISPER_COMPUTE_TYPE=int8
ORIGINAL_AUDIO_ALIGNMENT_MIN_SCORE=0.62
ORIGINAL_AUDIO_ALIGNMENT_SEARCH_WORDS=240
ORIGINAL_AUDIO_ALIGNMENT_INITIAL_SEARCH_WORDS=480
# Optional for manual local worker runs when ffmpeg is not on PATH
FFMPEG_BINARY=/opt/homebrew/bin/ffmpeg
FFPROBE_BINARY=/opt/homebrew/bin/ffprobe
# Local manual worker: ./public/audio
# Docker compose overrides this to /app/public/audio
AUDIO_PUBLIC_DIR=./public/audio
SCRAPER_CALLBACK_BASE_URL=http://localhost:3000
SCRAPER_WORKER_SECRET=
BROWSER_CDP_URL=http://chrome:9222

# Deployment image (used by docker-compose.deploy.yml)
ECHOREAD_IMAGE=ghcr.io/warjiang/echoread:latest
APP_PORT=3000

# TTS Configuration (edge | openai)
TTS_PROVIDER=edge

# Optional: OpenAI TTS
OPENAI_API_KEY=
OPENAI_BASE_URL=

# LLM material generation
LLM_PROVIDER=openai-compatible
LLM_MODEL_HIGH_QUALITY=gpt-4.1
LLM_BASE_URL=
LLM_API_KEY=
LLM_RESPONSE_FORMAT=json_object
LLM_TEMPERATURE=0.4
# Optional: protect /api/materials/worker
MATERIAL_WORKER_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
