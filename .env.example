# Database
DATABASE_URL="file:./prisma/dev.db"

# WSJ Credentials
WSJ_EMAIL=your_email@example.com
WSJ_PASSWORD=your_password
WSJ_STORAGE_PATH=./data/.wsj-auth.json

# Browser-use WSJ worker
WSJ_WORKER_URL=http://localhost:8000/scrape
SCRAPER_WORKER_SECRET=
BROWSER_CDP_URL=http://chrome:9222
BROWSER_AGENT_MODEL=gpt-4.1-mini
BROWSER_AGENT_BASE_URL=
BROWSER_AGENT_API_KEY=
BROWSER_AGENT_MAX_STEPS=80
BROWSER_AGENT_RESPONSE_FORMAT=prompt_json

# Deployment image (used by docker-compose.deploy.yml)
ECHOREAD_IMAGE=ghcr.io/warjiang/echoread:latest
APP_PORT=3000

# TTS Configuration (edge | openai)
TTS_PROVIDER=edge

# Optional: OpenAI TTS
OPENAI_API_KEY=
OPENAI_BASE_URL=

# LLM material generation
LLM_PROVIDER=openai-compatible
LLM_MODEL_HIGH_QUALITY=gpt-4.1
LLM_BASE_URL=
LLM_API_KEY=
LLM_RESPONSE_FORMAT=json_object
LLM_TEMPERATURE=0.4
# Optional: protect /api/materials/worker
MATERIAL_WORKER_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
