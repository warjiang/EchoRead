{
  "name": "shadow-reading",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "drizzle-kit migrate && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:auth": "tsx --test src/lib/auth/__tests__/*.test.ts",
    "test:db": "tsx --test src/db/__tests__/drizzle-smoke.test.ts",
    "test:materials": "tsx --test src/lib/materials/__tests__/*.test.ts",
    "test:original-audio": "tsx --test src/lib/original-audio/__tests__/queue.test.ts",
    "test:scraper": "tsx --test src/lib/scraper/__tests__/jobs.test.ts",
    "test:admin": "tsx --test src/lib/admin/__tests__/*.test.ts",
    "scrape": "tsx scripts/cron-scrape.ts",
    "worker": "tsx scripts/pipeline-worker.ts",
    "worker:once": "tsx scripts/pipeline-worker.ts --once",
    "worker:scrape": "tsx scripts/pipeline-worker.ts --once --stage=scrape",
    "worker:materials": "tsx scripts/pipeline-worker.ts --once --stage=materials",
    "worker:audio": "tsx scripts/pipeline-worker.ts --once --stage=audio",
    "worker:e2e": "tsx scripts/pipeline-worker.ts --once --stage=all",
    "worker:python": "cd worker/wsj-worker && uv run python -m app.runner",
    "worker:python:once": "cd worker/wsj-worker && uv run python -m app.runner --once",
    "cleanup:scraped": "tsx scripts/cleanup-scraped-data.ts",
    "wsj:login": "tsx scripts/wsj-login.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@next/env": "16.2.6",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compromise": "^14.15.1",
    "drizzle-orm": "^0.45.2",
    "edge-tts": "^1.0.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "playwright": "^1.60.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
