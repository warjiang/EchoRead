generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id          String   @id @default(cuid())
  title       String
  url         String   @unique
  content     String
  summary     String?
  category    String?
  difficulty  String?
  publishedAt DateTime
  createdAt   DateTime @default(now())
  sentences   Sentence[]
  readings    ReadingHistory[]
  trainingPackage TrainingPackage?
  materialJobs MaterialJob[]
}

model ScrapeJob {
  id           String    @id @default(cuid())
  status       String    @default("pending")
  maxArticles  Int       @default(5)
  createdCount Int       @default(0)
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, createdAt])
}

model Sentence {
  id        String  @id @default(cuid())
  articleId String
  index     Int
  text      String
  audioUrl  String?
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model Vocabulary {
  id         String   @id @default(cuid())
  word       String
  definition String?
  context    String?
  articleId  String?
  mastered   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([word])
}

model ReadingHistory {
  id          String   @id @default(cuid())
  articleId   String
  progress    Float    @default(0)
  shadowDone  Boolean  @default(false)
  duration    Int      @default(0)
  createdAt   DateTime @default(now())
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model TrainingPackage {
  id            String   @id @default(cuid())
  articleId     String   @unique
  version       Int      @default(1)
  status        String   @default("pending")
  model         String?
  promptVersion String   @default("v1")
  payloadJson   String?
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  article       Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model MaterialJob {
  id         String   @id @default(cuid())
  articleId  String
  jobType    String   @default("full_training_pack")
  status     String   @default("pending")
  attempts   Int      @default(0)
  maxAttempts Int     @default(3)
  runAfter   DateTime @default(now())
  lockedAt   DateTime?
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([status, runAfter])
  @@unique([articleId, jobType])
}
